<resources>
    <!-- Beta indicator -->
    <bool name="is_beta">false</bool>
    <bool name="dev_version_direct_download_enabled">false</bool>

    <!-- App name and other strings -->
    <string name="app_name">Vida Cloud</string>
    <string name="account_type">vidacloud</string>     <!-- changing this from "nextcloud" intentionally so this is a clean fork; existing Nextcloud accounts won't migrate -->
    <string name="authority">com.vidatools.cloud</string>
    <string name="users_and_groups_search_authority">com.vidatools.cloud.providers.UsersAndGroupsSearchProvider</string>
    <string name="users_and_groups_share_with">com.vidatools.cloud.providers.UsersAndGroupsSearchProvider.action.SHARE_WITH</string>
    <string name="document_provider_authority">com.vidatools.cloud.documents</string>
    <string name="file_provider_authority">com.vidatools.cloud.files</string>
    <string name="image_cache_provider_authority">com.vidatools.cloud.imageCache.provider</string>
    <string name="db_file">vidacloud.db</string>
    <string name="db_name">vidacloud</string>
    <string name="data_folder">VidaCloud</string>
    <string name="default_display_name_for_root_folder">Vida Cloud</string>
    <string name="nextcloud_user_agent">Mozilla/5.0 (Android) VidaCloud-android/%1$s%2$s</string>
    <string name="only_office_user_agent">Mozilla/5.0 (Android %1$s) Mobile VidaCloud-android/%2$s</string>
    <string name="name_for_branded_user_agent">VidaCloud</string>

    <!-- URLs and flags related -->
    <bool name="show_server_url_input">false</bool>
    <bool name="show_provider_or_own_installation">false</bool>
    <string name="provider_registration_server"></string>

    <!-- specify built in proxy -->
    <string name="proxy_host"></string>
    <integer name="proxy_port">-1</integer>

    <bool name="disable_intro">false</bool>
    <bool name="disable_multiaccount">false</bool>
    <bool name="disable_more_external_site">false</bool>
    <bool name="disable_sharing">false</bool>
    <bool name="disable_clipboard">false</bool>
    <bool name="disable_log">false</bool>
    <bool name="enforce_protection">false</bool>

    <!-- Flags to enable/disable some features -->
    <string name="send_files_to_other_apps">on</string>
    <bool name="share_via_link_feature">true</bool>
    <bool name="share_with_users_feature">true</bool>
    <bool name="show_external_links">true</bool>
    <bool name="show_outdated_server_warning">true</bool>
    <!-- is_branded_client=true suppresses Nextcloud ecosystem-app suggestions
         and source-code-link prompts. Recommended for OEM rebrands. -->
    <bool name="is_branded_client">true</bool>
    <bool name="is_branded_plus_client">false</bool>

    <!-- Calendar & Contacts backup -->
    <string name="contacts_backup_folder">/.Contacts-Backup</string>
    <integer name="contacts_backup_expire">-1</integer>
    <string name="calendar_backup_folder">/.Calendar-Backup</string>
    <bool name="show_calendar_backup">true</bool>

    <!-- What's new -->
    <bool name="show_whats_new">true</bool>
    <array name="whatsnew_urls"></array>

    <!-- Colors — Vida sage primary -->
    <color name="primary">#6B8F71</color>
    <color name="primary_dark">#557159</color>
    <color name="color_accent">#8FB095</color>
    <color name="login_text_color">#ffffff</color>
    <color name="login_text_hint_color">#cfe0d2</color>

    <!-- Multiaccount support -->
    <bool name="multiaccount_support">true</bool>

    <!-- Drawer options -->
    <bool name="shared_enabled">true</bool>
    <bool name="show_drawer_logout">false</bool>

    <!-- Help, imprint and feedback -->
    <bool name="passcode_enabled">true</bool>
    <bool name="device_credentials_enabled">true</bool>
    <bool name="show_hidden_files_enabled">true</bool>
    <bool name="davdroid_integration_enabled">true</bool>
    <bool name="help_enabled">true</bool>
    <string name="url_help">https://vidatools.com/help/cloud/android/</string>
    <bool name="privacy_enabled">true</bool>
    <string name="privacy_url">https://vidatools.com/privacy</string>
    <bool name="imprint_enabled">false</bool>
    <bool name="recommend_enabled">false</bool>
    <bool name="logger_enabled">false</bool>
    <!-- AGPL requires we make source available — link to the public fork. -->
    <bool name="sourcecode_enabled">true</bool>
    <string name="sourcecode_url" translatable="false">https://github.com/gandfrey/vida-cloud-android</string>
    <bool name="license_enabled">true</bool>
    <string name="license_url" translatable="false">https://www.gnu.org/licenses/agpl-3.0.html</string>
    <string name="url_imprint"></string>
    <string name="url_app_download">"https://play.google.com/store/apps/details?id=com.vidatools.cloud"</string>
    <string name="url_server_install"></string>

    <!-- synced folder light; if enabled: move to setting & global upload settings -->
    <bool name="syncedFolder_light">false</bool>
    <string name="syncedFolder_remote_folder">@string/auto_upload_path</string>
    <bool name="syncedFolder_light_on_charging">false</bool>
    <bool name="syncedFolder_light_use_subfolders">false</bool>
    <string name="syncedFolder_light_upload_behaviour">FilesUploadWorker.LOCAL_BEHAVIOUR_FORGET</string>

    <!-- Destination mail for sending log files -->
    <string name="mail_logger"></string>

    <!-- Determine is participate enabled -->
    <bool name="participate_enabled">false</bool>
    <string name="fdroid_beta_link" translatable="false"></string>
    <string name="beta_apk_link" translatable="false"></string>
    <string name="play_store_register_beta" translatable="false"></string>
    <string name="fdroid_link" translatable="false"></string>
    <string name="help_link" translatable="false">https://vidatools.com/help/cloud/</string>
    <string name="translation_link" translatable="false"></string>
    <string name="contributing_link" translatable="false">https://github.com/gandfrey/vida-cloud-android/blob/master/CONTRIBUTING.md</string>
    <string name="report_issue_link" translatable="false">https://github.com/gandfrey/vida-cloud-android/issues/new?template=bug_report.yml</string>
    <string name="report_issue_empty_link" translatable="false">https://github.com/gandfrey/vida-cloud-android/issues/new/choose</string>

    <!-- login data links -->
    <string name="login_data_own_scheme" translatable="false">vc</string>
    <!-- Pre-fill the Vida Cloud server URL via the webview login flow.
         When set, this overrides all other login methods available. -->
    <string name="webview_login_url" translatable="false">https://vidatools.com/cloud/index.php/login/flow</string>

    <!-- Lock to Vida Cloud only — no other servers selectable. -->
    <string name="enforce_servers" translatable="false">[{"name":"Vida Cloud","url":"https://vidatools.com/cloud"}]</string>

    <!-- Files becomes Home -->
    <bool name="use_home">false</bool>

    <!-- Push server url — leave blank to use the server's own notify_push relay.
         To stand up a private relay, set to e.g. https://push.vidatools.com -->
    <string name="push_server_url" translatable="false"></string>

    <!-- Splash screen branding text shown below the icon -->
    <string name="splashScreenBold">Vida Cloud</string>
    <string name="splashScreenNormal">by Vida Design</string>

    <!-- Geocoding -->
    <string name="osm_geocoder_url" translatable="false">https://nominatim.openstreetmap.org/</string>
    <string name="osm_geocoder_contact" translatable="false">support@vidatools.com</string>


    <!-- Dev settings -->
    <string name="dev_link"></string>
    <string name="dev_latest"></string>
    <string name="dev_changelog">https://github.com/gandfrey/vida-cloud-android/raw/dev/CHANGELOG.md</string>

    <string name="buildNumber" translatable="false"></string>
</resources>
